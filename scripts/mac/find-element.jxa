#!/usr/bin/env osascript -l JavaScript

/**
 * find-element.jxa
 *
 * Searches the UI tree for elements matching given criteria.
 *
 * Accepts both macOS/JXA arg names and Windows PS1 arg names so the same
 * TypeScript call site works on both platforms:
 *
 *   macOS args  →  Windows aliases
 *   -name           -Name
 *   -role           -ControlType  (with ControlType→role mapping below)
 *   -processId      -ProcessId
 *
 * Returns JSON array of matches with:
 *   - name: Element name/label
 *   - role: macOS accessibility role (AXButton, AXTextField, …)
 *   - bounds: {x, y, width, height}
 *   - processId: Owning process PID
 *   - value: Current value (if applicable)
 *
 * Usage: osascript -l JavaScript find-element.jxa -name "OK" -role "button" -processId 1234
 *   or:  osascript -l JavaScript find-element.jxa -ControlType Button -ProcessId 1234
 */

ObjC.import('stdlib');

// Map Windows UI Automation ControlType names → macOS AX role substrings
var CONTROL_TYPE_MAP = {
    'Button':      'AXButton',
    'Edit':        'AXTextField',
    'Document':    'AXWebArea',
    'ComboBox':    'AXComboBox',
    'CheckBox':    'AXCheckBox',
    'RadioButton': 'AXRadioButton',
    'Hyperlink':   'AXLink',
    'MenuItem':    'AXMenuItem',
    'Menu':        'AXMenu',
    'Tab':         'AXTabGroup',
    'TabItem':     'AXTab',
    'ListItem':    'AXCell',
    'TreeItem':    'AXOutlineRow',
    'Slider':      'AXSlider',
    'ScrollBar':   'AXScrollBar',
    'ToolBar':     'AXToolbar',
    'StaticText':  'AXStaticText',
    'Text':        'AXStaticText',
    'Window':      'AXWindow',
    'Group':       'AXGroup',
};

// Parse command line arguments — accept both macOS and Windows PS1 naming
function parseArgs() {
    var args = ObjC.unwrap($.NSProcessInfo.processInfo.arguments);
    var result = { name: null, role: null, processId: null };

    for (var i = 0; i < args.length; i++) {
        var arg = ObjC.unwrap(args[i]);
        var next = i + 1 < args.length ? ObjC.unwrap(args[i + 1]) : null;

        if ((arg === '-name' || arg === '-Name') && next) {
            result.name = next;
        } else if (arg === '-role' && next) {
            result.role = next;
        } else if (arg === '-ControlType' && next) {
            // Translate Windows ControlType to macOS AX role
            result.role = CONTROL_TYPE_MAP[next] || ('AX' + next);
        } else if ((arg === '-processId' || arg === '-ProcessId') && next) {
            result.processId = parseInt(next, 10);
        }
        // -AutomationId has no macOS equivalent; silently ignore
    }

    return result;
}

function safeGet(obj, prop, def) {
    try { var v = obj[prop](); return (v !== undefined && v !== null) ? v : def; } catch (e) { return def; }
}

// Map macOS AX role → System Events typed-collection accessor (much faster than uiElements())
var ROLE_TO_COLLECTION = {
    'AXButton':      'buttons',
    'AXTextField':   'textFields',
    'AXTextArea':    'textAreas',
    'AXComboBox':    'popUpButtons',
    'AXCheckBox':    'checkboxes',
    'AXRadioButton': 'radioButtons',
    'AXScrollArea':  'scrollAreas',
    'AXList':        'lists',
    'AXTable':       'tables',
    'AXOutline':     'outlines',
    'AXGroup':       'groups',
    'AXStaticText':  'staticTexts',
    'AXImage':       'images',
    'AXSlider':      'sliders',
    'AXToolbar':     'toolbars',
};

function getBounds(el) {
    try {
        var pos = el.position();
        var sz  = el.size();
        return { x: pos[0] || 0, y: pos[1] || 0, width: sz[0] || 0, height: sz[1] || 0 };
    } catch (e) {
        return { x: 0, y: 0, width: 0, height: 0 };
    }
}

function matchElement(el, targetName, targetRole) {
    var elName  = ''; try { elName  = el.name()  || ''; } catch (e) {}
    var elRole  = ''; try { elRole  = el.role()  || ''; } catch (e) {}
    var elValue = ''; try { elValue = el.value() || ''; } catch (e) {}

    var nameMatch = !targetName ||
        (elName && elName.toLowerCase().indexOf(targetName.toLowerCase()) !== -1);
    var roleMatch = !targetRole ||
        (elRole && elRole.toLowerCase().indexOf(targetRole.toLowerCase()) !== -1);

    if (nameMatch && roleMatch && (elName || elRole)) {
        return { name: elName, role: elRole, value: elValue, bounds: getBounds(el) };
    }
    return null;
}

/**
 * Search a window for matching elements.
 * Strategy:
 *   1. If a specific role is requested and maps to a typed collection, use that
 *      (fast — single System Events call, no recursion).
 *   2. Otherwise fall back to shallow uiElements() scan (depth 2 max) to avoid hangs.
 */
function searchWindow(win, targetName, targetRole, maxResults, results) {
    var collection = targetRole ? ROLE_TO_COLLECTION[targetRole] : null;

    if (collection) {
        // Fast path: typed collection (AXButton → buttons, etc.)
        try {
            var els = win[collection]();
            for (var i = 0; i < els.length && results.length < maxResults; i++) {
                try {
                    var m = matchElement(els[i], targetName, targetRole);
                    if (m) results.push(m);
                } catch (e) {}
            }
        } catch (e) {}
        // Also check inside groups one level deep
        try {
            var groups = win.groups();
            for (var g = 0; g < groups.length && results.length < maxResults; g++) {
                try {
                    var gels = groups[g][collection]();
                    for (var gi = 0; gi < gels.length && results.length < maxResults; gi++) {
                        try {
                            var gm = matchElement(gels[gi], targetName, targetRole);
                            if (gm) results.push(gm);
                        } catch (e) {}
                    }
                } catch (e) {}
            }
        } catch (e) {}
    } else {
        // Slow path: shallow generic scan (depth 2)
        var collectionsToSearch = ['buttons', 'textFields', 'textAreas', 'checkboxes',
                                   'radioButtons', 'popUpButtons', 'staticTexts', 'groups'];
        for (var ci = 0; ci < collectionsToSearch.length && results.length < maxResults; ci++) {
            try {
                var celems = win[collectionsToSearch[ci]]();
                for (var ce = 0; ce < celems.length && results.length < maxResults; ce++) {
                    try {
                        var cm = matchElement(celems[ce], targetName, targetRole);
                        if (cm) results.push(cm);
                    } catch (e) {}
                }
            } catch (e) {}
        }
    }
}

var output;
try {
    var params = parseArgs();
    var SystemEvents = Application('System Events');
    SystemEvents.includeStandardAdditions = true;

    var results = [];
    var maxResults = 20;

    // Require processId OR name to avoid searching every window in every app
    if (!params.processId && !params.name) {
        output = JSON.stringify([]);
    } else {
        // Get target process(es)
        var targetProcesses;
        if (params.processId) {
            targetProcesses = SystemEvents.processes.where({ unixId: params.processId });
            if (targetProcesses.length === 0) {
                output = JSON.stringify({ error: 'No process found with ID ' + params.processId });
                $.exit(0);
            }
        } else {
            targetProcesses = SystemEvents.processes.where({ backgroundOnly: false });
        }

        // Search each process
        for (var p = 0; p < targetProcesses.length && results.length < maxResults; p++) {
            try {
                var proc = targetProcesses[p];
                var procId = safeGet(proc, 'unixId', 0);
                var beforeCount = results.length;

                var windows = proc.windows;
                for (var w = 0; w < windows.length && results.length < maxResults; w++) {
                    try {
                        searchWindow(windows[w], params.name, params.role, maxResults, results);
                    } catch (e) {}
                }

                // Stamp the processId on any newly-added results
                for (var r = beforeCount; r < results.length; r++) {
                    results[r].processId = procId;
                }
            } catch (e) {}
        }

        output = JSON.stringify(results, null, 0);
    }
} catch (error) {
    output = JSON.stringify({ error: error.toString() });
    $.exit(1);
}
output;
